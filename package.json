{
  "name": "gate-paste",
  "version": "1.0.0",
  "description": "Detect secrets in your clipboard before you paste into web forms.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "recheck --version && echo 'recheck available in CI'",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.60.0",
    "recheck": "^4.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  }
}
